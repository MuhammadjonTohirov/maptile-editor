{
  "version": 8,
  "name": "Uzbekistan OSM Bright Editor",
  "metadata": {
    "maplibre:type": "map",
    "maptile-editor:base": "OpenMapTiles-compatible Uzbekistan archive"
  },
  "glyphs": "/fonts/{fontstack}/{range}",
  "sources": {
    "osm_base": {
      "type": "vector",
      "tiles": [
        "/tiles/base/{z}/{x}/{y}"
      ],
      "minzoom": 0,
      "maxzoom": 14,
      "attribution": "© OpenMapTiles © OpenStreetMap contributors"
    },
    "editor": {
      "type": "vector",
      "tiles": [
        "/tiles/editor/{z}/{x}/{y}"
      ],
      "minzoom": 0,
      "maxzoom": 20,
      "promoteId": "id"
    },
    "editor_anchors": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": []
      }
    },
    "road_connectivity": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": []
      }
    },
    "road_guidance": {
