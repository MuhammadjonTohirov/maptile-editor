      "type": "fill",
      "source": "osm_base",
      "source-layer": "landcover",
      "paint": {
        "fill-color": [
          "match",
          [
            "get",
            "class"
          ],
          "wood",
          "#c9dfb9",
          "grass",
          "#d9edc9",
          "#eaf1e6"
        ]
      }
    },
