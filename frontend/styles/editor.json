        "text-color": "#596675",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "base-buildings-3d",
      "type": "fill-extrusion",
      "source": "osm_base",
      "source-layer": "building",
      "minzoom": 15,
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "fill-extrusion-color": "#d5cec6",
        "fill-extrusion-height": [
          "coalesce",
          [
            "get",
            "render_height"
          ],
          [
            "get",
            "height"
          ],
          8
        ],
        "fill-extrusion-base": [
          "coalesce",
          [
            "get",
            "render_min_height"
          ],
          0
        ],
        "fill-extrusion-opacity": 0.82
      }
    },
    {
      "id": "editor-road-guidance-highlight",
      "type": "line",
      "source": "road_guidance",
      "minzoom": 15,
      "filter": ["==", ["get", "kind"], "selected"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#22d3ee",
        "line-width": 8,
        "line-opacity": 0.72
      }
    },
    {
      "id": "editor-road-direction-arrows",
      "type": "symbol",
      "source": "road_guidance",
      "minzoom": 15,
      "filter": ["==", ["get", "kind"], "direction"],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 65,
        "icon-image": "road-direction-arrow",
        "icon-size": 0.9,
        "icon-rotation-alignment": "map",
        "icon-pitch-alignment": "map",
        "icon-keep-upright": false,
        "icon-allow-overlap": true
      },
      "paint": {
        "icon-opacity": 1
      }
    },
    {
      "id": "editor-road-turn-arrows",
      "type": "symbol",
      "source": "road_guidance",
      "minzoom": 20,
      "filter": ["==", ["get", "kind"], "turn-arrow"],
      "layout": {
        "icon-image": [
          "case",
          ["==", ["get", "maneuver"], "uturn"],
          "road-uturn-arrow",
          "road-turn-arrow"
        ],
        "icon-size": 0.625,
        "icon-anchor": "center",
        "icon-offset": [
          "case",
          ["==", ["get", "maneuver"], "uturn"],
          ["literal", [0, 56]],
          ["literal", [0, -64]]
        ],
        "icon-rotate": ["get", "bearing"],
        "icon-rotation-alignment": "map",
        "icon-pitch-alignment": "map",
        "icon-allow-overlap": true,
        "icon-ignore-placement": true
      },
      "paint": {
        "icon-opacity": 1
      }
    },
    {
      "id": "editor-road-connectivity",
      "type": "circle",
      "source": "road_connectivity",
      "minzoom": 15,
      "paint": {
        "circle-radius": 4,
        "circle-color": [
          "case",
          ["get", "connected"],
          "#16a34a",
          "#ef4444"
        ],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.5
      }
    },
    {
      "id": "editor-snap-indicator",
      "type": "circle",
      "source": "snap_indicator",
      "paint": {
        "circle-radius": 9,
        "circle-color": "#16a34a",
        "circle-opacity": 0.25,
        "circle-stroke-color": "#16a34a",
        "circle-stroke-width": 2
      }
    },
    {
      "id": "editor-route-line-casing",
      "type": "line",
      "source": "route_line",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": 7,
        "line-opacity": 0.8
      }
    },
    {
      "id": "editor-route-line-foot",
      "type": "line",
      "source": "route_line",
      "filter": ["==", ["get", "profile"], "foot"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#2563eb",
        "line-width": 4.5,
        "line-dasharray": [2, 1.5],
        "line-opacity": 0.92
      }
    },
    {
      "id": "editor-route-line-bicycle",
      "type": "line",
      "source": "route_line",
      "filter": ["==", ["get", "profile"], "bicycle"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#0f9f8f",
        "line-width": 4.5,
        "line-dasharray": [0.75, 1.15],
        "line-opacity": 0.92
      }
    },
    {
      "id": "editor-route-line",
      "type": "line",
      "source": "route_line",
      "filter": ["==", ["get", "profile"], "car"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#7c3aed",
        "line-width": 5,
        "line-opacity": 0.9
      }
    },
    {
      "id": "editor-route-points",
      "type": "circle",
      "source": "route_points",
      "paint": {
        "circle-radius": 10,
        "circle-color": "#ffffff",
        "circle-stroke-color": [
          "match",
          ["get", "profile"],
          "car", "#7c3aed",
          "bicycle", "#0f9f8f",
          "#2563eb"
        ],
        "circle-stroke-width": 3
      }
    },
    {
      "id": "editor-route-point-labels",
      "type": "symbol",
      "source": "route_points",
      "layout": {
        "text-field": ["get", "label"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "text-allow-overlap": true,
        "text-ignore-placement": true
      },
      "paint": {
        "text-color": "#172033"
      }
    }
  ]
}
